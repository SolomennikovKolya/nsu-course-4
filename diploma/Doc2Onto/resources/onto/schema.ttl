@prefix : <http://doc2onto.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://doc2onto.org/ontology> rdf:type owl:Ontology ;
    rdfs:label "Онтология учебного процесса кафедры"@ru ;
    rdfs:comment """Онтология предметной области «кафедра общей информатики университета».
Цель — формализованное хранение знаний учебного процесса кафедры в виде, обеспечивающем
надёжное автоматическое извлечение фактов из документов и их детерминированное добавление
в граф знаний.

Принципы идентификации индивидов:
  1. Индивиды, чья текстовая идентификация неоднозначна (ФИО, названия организаций,
     темы ВКР и т. п.), получают IRI в виде хеша от нормализованной формы
     идентифицирующих признаков. Сами признаки одновременно сохраняются как
     литеральные свойства индивида.
  2. Индивиды с заведомо стабильным «техническим» идентификатором (номер группы,
     код направления подготовки, учебный год, семестр) хешированию не подвергаются —
     для них используется либо литерал, либо IRI, безопасно построенный из самого
     идентификатора.
  3. Перечисляемые типы (должность, учёная степень, учёное звание, вид практики,
     итоговая оценка) выражены закрытыми списками именованных индивидов
     с предсказуемыми IRI вида :<Класс>_<Значение> для детерминированного маппинга
     из текста.

Принципы стабильности модели:
  • Документ — лишь источник фактов; знания не привязаны к документу как к «центру».
  • Ограничения existential/cardinality на уровне TBox намеренно сведены к минимуму:
    добавление новой частичной информации о существующем индивиде не должно нарушать
    модель.
  • Соответствие классам выводится по rdfs:domain / rdfs:range объектных и
    данных-свойств — это даёт мягкую типизацию и устойчивость к неполным данным.""" .


# =====================================================================
# ПОЛИТИКИ СЛИЯНИЯ ФАКТОВ (annotation property + закрытое перечисление)
# =====================================================================

# При добавлении в общий граф фактов из документа возможны конфликты:
#   у одной и той же сущности (s, p, ?) уже есть какое-то значение,
#   а новый документ приносит другое. Поведение задаётся аннотацией
#   :mergePolicy у самого предиката p.
# 
#   :Policy_Set        — single-valued, неизменное во времени:
#                        полная замена (s, p, *) → (s, p, o_new) без учёта дат.
#                        Применяется к идентифицирующим свойствам и связям,
#                        смена которых = ошибка извлечения.
# 
#   :Policy_SetByDate  — single-valued, временное:
#                        замена выполняется только если effective_date нового
#                        факта ≥ effective_date уже хранящегося. Иначе новый
#                        факт игнорируется (журналируется как rejected).
#                        Применяется к свойствам, отражающим состояние
#                        агента во времени (группа обучения, тема ВКР).
# 
#   :Policy_Add        — multi-valued: чистый add, ничего не вытесняет.
#                        Применяется к множественным свойствам (телефоны,
#                        учёные звания, варианты наименования и т. п.),
#                        а также к rdf:type (по умолчанию).
# 
#   Дефолт для свойства без явной :mergePolicy — :Policy_Add.

:MergePolicy rdf:type owl:Class ;
    rdfs:label "Политика слияния фактов"@ru ;
    rdfs:comment "Класс политик слияния значений предиката при добавлении фактов в общий граф." .

:Policy_Set rdf:type owl:NamedIndividual, :MergePolicy ;
    rdfs:label "set"@ru ;
    rdfs:comment "Single-valued, неизменное во времени: полная замена (s, p, *) → (s, p, o_new)." .

:Policy_SetByDate rdf:type owl:NamedIndividual, :MergePolicy ;
    rdfs:label "set-by-date"@ru ;
    rdfs:comment "Single-valued, временное: замена выполняется только если effective_date нового факта ≥ существующего." .

:Policy_Add rdf:type owl:NamedIndividual, :MergePolicy ;
    rdfs:label "add"@ru ;
    rdfs:comment "Multi-valued: чистый add, ничего не вытесняет (дефолт)." .

:mergePolicy rdf:type owl:AnnotationProperty ;
    rdfs:label "политика слияния"@ru ;
    rdfs:domain rdf:Property ;
    rdfs:range :MergePolicy ;
    rdfs:comment "Аннотация предиката, определяющая поведение при слиянии фактов о (s, p, ?)." .


# =====================================================================
# КЛАССЫ
# =====================================================================

# ---------- Агенты: персоны и организации ----------

:Агент rdf:type owl:Class ;
    rdfs:label "Агент"@ru ;
    rdfs:comment "Действующее лицо предметной области: персона либо организация." .

# --- Персоны ---

:Персона rdf:type owl:Class ;
    rdfs:subClassOf :Агент ;
    rdfs:label "Персона"@ru ;
    rdfs:comment """Физическое лицо. IRI индивида формируется как детерминированный
хеш от нормализованного представления ФИО (нижний регистр, без лишних пробелов,
с заменой 'ё' на 'е' и т. п.). Сами фамилия, имя и отчество одновременно сохраняются
как литералы через :фамилия / :имя / :отчество. Один и тот же человек может
одновременно являться и :Студент, и :Сотрудник — эти подклассы не дизъюнктны.""" .

:Студент rdf:type owl:Class ;
    rdfs:subClassOf :Персона ;
    rdfs:label "Студент"@ru ;
    rdfs:comment "Персона в роли обучающегося. Не дизъюнктен с :Сотрудник." .

:Сотрудник rdf:type owl:Class ;
    rdfs:subClassOf :Персона ;
    rdfs:label "Сотрудник"@ru ;
    rdfs:comment "Персона в роли работника университета или внешней организации." .

# --- Организации ---

:Организация rdf:type owl:Class ;
    rdfs:subClassOf :Агент ;
    rdfs:label "Организация"@ru ;
    rdfs:comment """Юридическое лицо или его структурное подразделение. IRI — хеш
от нормализованной канонической формы основного наименования. Все известные варианты
наименования (полное, краткое, аббревиатура) хранятся как :названиеОрганизации.""" .

:Университет rdf:type owl:Class ;
    rdfs:subClassOf :Организация ;
    rdfs:label "Университет"@ru ;
    rdfs:comment "Высшее учебное заведение." .

:СтруктурноеПодразделение rdf:type owl:Class ;
    rdfs:subClassOf :Организация ;
    rdfs:label "Структурное подразделение"@ru ;
    rdfs:comment "Часть организации, связанная с родителем через :входитВ." .

:Факультет rdf:type owl:Class ;
    rdfs:subClassOf :СтруктурноеПодразделение ;
    rdfs:label "Факультет"@ru .

:Кафедра rdf:type owl:Class ;
    rdfs:subClassOf :СтруктурноеПодразделение ;
    rdfs:label "Кафедра"@ru .

:Лаборатория rdf:type owl:Class ;
    rdfs:subClassOf :СтруктурноеПодразделение ;
    rdfs:label "Лаборатория"@ru ;
    rdfs:comment "Научная или учебная лаборатория, как правило часть факультета или внешнего НИИ." .

:ВнешняяОрганизация rdf:type owl:Class ;
    rdfs:subClassOf :Организация ;
    rdfs:label "Внешняя организация"@ru ;
    rdfs:comment "Организация, не являющаяся частью университета (НИИ, предприятие — место прохождения практики, работодатель и т. п.)." .

# Дизъюнктность: персона и организация не пересекаются.
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Персона :Организация ) .

# Дизъюнктность типов организаций (одна и та же организация не может одновременно
# быть, например, факультетом и кафедрой).
[] rdf:type owl:AllDisjointClasses ;
   owl:members ( :Университет :Факультет :Кафедра :Лаборатория :ВнешняяОрганизация ) .


# ---------- Образовательная структура ----------

:Группа rdf:type owl:Class ;
    rdfs:label "Учебная группа"@ru ;
    rdfs:comment """Студенческая группа. IRI формируется напрямую из номера группы
(например, :Группа_22204) — номер сам по себе является стабильным идентификатором,
хеш не требуется. Номер также сохраняется как литерал :номерГруппы.""" .

:НаправлениеПодготовки rdf:type owl:Class ;
    rdfs:label "Направление подготовки"@ru ;
    rdfs:comment """Образовательное направление (например, '09.03.01 Информатика и
вычислительная техника'). IRI образуется из кода направления с заменой точек на
подчёркивания: :Направление_09_03_01. Код и название хранятся как литералы.""" .

:Профиль rdf:type owl:Class ;
    rdfs:label "Профиль (направленность) подготовки"@ru ;
    rdfs:comment "Профиль образовательной программы. IRI — хеш от нормализованного названия." .

# ---------- Академические активности ----------

:АкадемическаяАктивность rdf:type owl:Class ;
    rdfs:label "Академическая активность"@ru ;
    rdfs:comment "Длящаяся работа или событие учебного процесса (ВКР, практика и т. п.)." .

:ВКР rdf:type owl:Class ;
    rdfs:subClassOf :АкадемическаяАктивность ;
    rdfs:label "Выпускная квалификационная работа"@ru ;
    rdfs:comment """ВКР конкретного студента. IRI — хеш от IRI студента (одна
ВКР на студента). Тема хранится как литерал :темаВКР; смена формулировки темы
обновляет литерал, а не порождает нового индивида.""" .

:Практика rdf:type owl:Class ;
    rdfs:subClassOf :АкадемическаяАктивность ;
    rdfs:label "Практика"@ru ;
    rdfs:comment """Учебная / производственная / преддипломная и т. п. практика
конкретного студента. IRI — хеш от пары (IRI студента, дата начала практики
в ISO-формате). Дата начала — стабильный естественный идентификатор: две
практики одного студента не могут начинаться в один день. Вид практики
(:видПрактики) хранится как литерал, без контролируемого словаря.""" .


# ---------- Перечисляемые типы (named-individual enums) ----------

# Все перечисления оформлены как owl:Class + список owl:NamedIndividual.
# IRI индивидов имеет форму :<Класс>_<Значение>, что обеспечивает однозначный
# и детерминированный маппинг из текста документа в граф.

:Должность rdf:type owl:Class ;
    rdfs:label "Должность"@ru ;
    rdfs:comment "Должность сотрудника. Закрытый перечень именованных индивидов." .

:УченаяСтепень rdf:type owl:Class ;
    rdfs:label "Учёная степень"@ru ;
    rdfs:comment "Учёная степень сотрудника. Закрытый перечень." .

:УченоеЗвание rdf:type owl:Class ;
    rdfs:label "Учёное звание"@ru ;
    rdfs:comment "Учёное звание сотрудника. Закрытый перечень." .

:Оценка rdf:type owl:Class ;
    rdfs:label "Итоговая оценка практики"@ru .


# =====================================================================
# ИМЕНОВАННЫЕ ИНДИВИДЫ ПЕРЕЧИСЛЕНИЙ
# =====================================================================

# ---------- Должности ----------

:Должность_ЗаведующийКафедрой rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "заведующий кафедрой"@ru .
:Должность_Декан rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "декан"@ru .
:Должность_Ректор rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "ректор"@ru .
:Должность_ДиректорИнститута rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "директор института"@ru .
:Должность_Профессор rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "профессор"@ru .
:Должность_Доцент rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "доцент"@ru .
:Должность_СтаршийПреподаватель rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "старший преподаватель"@ru .
:Должность_Преподаватель rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "преподаватель"@ru .
:Должность_Ассистент rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "ассистент"@ru .
:Должность_ГлавныйНаучныйСотрудник rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "главный научный сотрудник"@ru .
:Должность_ВедущийНаучныйСотрудник rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "ведущий научный сотрудник"@ru ;
    rdfs:comment "В тексте часто записывается как 'в.н.с.'." .
:Должность_СтаршийНаучныйСотрудник rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "старший научный сотрудник"@ru ;
    rdfs:comment "В тексте часто записывается как 'с.н.с.'." .
:Должность_НаучныйСотрудник rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "научный сотрудник"@ru .
:Должность_МладшийНаучныйСотрудник rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "младший научный сотрудник"@ru .
:Должность_Лаборант rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "лаборант"@ru .
:Должность_Секретарь rdf:type owl:NamedIndividual, :Должность ;
    rdfs:label "секретарь"@ru .

# ---------- Учёные степени ----------

:УченаяСтепень_КандидатФизМатНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "кандидат физико-математических наук"@ru ;
    rdfs:comment "к.ф.-м.н." .
:УченаяСтепень_ДокторФизМатНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "доктор физико-математических наук"@ru ;
    rdfs:comment "д.ф.-м.н." .
:УченаяСтепень_КандидатТехнНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "кандидат технических наук"@ru ;
    rdfs:comment "к.т.н." .
:УченаяСтепень_ДокторТехнНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "доктор технических наук"@ru ;
    rdfs:comment "д.т.н." .
:УченаяСтепень_КандидатПедНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "кандидат педагогических наук"@ru ;
    rdfs:comment "к.п.н." .
:УченаяСтепень_ДокторПедНаук rdf:type owl:NamedIndividual, :УченаяСтепень ;
    rdfs:label "доктор педагогических наук"@ru ;
    rdfs:comment "д.п.н." .

# ---------- Учёные звания ----------

:УченоеЗвание_Доцент rdf:type owl:NamedIndividual, :УченоеЗвание ;
    rdfs:label "доцент"@ru .
:УченоеЗвание_Профессор rdf:type owl:NamedIndividual, :УченоеЗвание ;
    rdfs:label "профессор"@ru .
:УченоеЗвание_ЧленКорреспондентРАН rdf:type owl:NamedIndividual, :УченоеЗвание ;
    rdfs:label "член-корреспондент РАН"@ru .
:УченоеЗвание_АкадемикРАН rdf:type owl:NamedIndividual, :УченоеЗвание ;
    rdfs:label "академик РАН"@ru .
:УченоеЗвание_АкадемикРИА rdf:type owl:NamedIndividual, :УченоеЗвание ;
    rdfs:label "академик РИА"@ru .

# ---------- Итоговые оценки ----------

:Оценка_Отлично rdf:type owl:NamedIndividual, :Оценка ;
    rdfs:label "отлично"@ru .
:Оценка_Хорошо rdf:type owl:NamedIndividual, :Оценка ;
    rdfs:label "хорошо"@ru .
:Оценка_Удовлетворительно rdf:type owl:NamedIndividual, :Оценка ;
    rdfs:label "удовлетворительно"@ru .
:Оценка_Неудовлетворительно rdf:type owl:NamedIndividual, :Оценка ;
    rdfs:label "неудовлетворительно"@ru .


# =====================================================================
# ОБЪЕКТНЫЕ СВОЙСТВА
# =====================================================================

# ---------- Структура организаций ----------

:входитВ rdf:type owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:label "входит в"@ru ;
    rdfs:domain :Организация ;
    rdfs:range :Организация ;
    :mergePolicy :Policy_Set ;
    rdfs:comment "Иерархическая принадлежность подразделения к родительской организации. Транзитивно: кафедра входит в факультет → кафедра входит в университет." .

# ---------- Студент ----------

:обучаетсяВГруппе rdf:type owl:ObjectProperty ;
    rdfs:label "обучается в группе"@ru ;
    rdfs:domain :Студент ;
    rdfs:range :Группа ;
    :mergePolicy :Policy_SetByDate .

:обучаетсяНаНаправлении rdf:type owl:ObjectProperty ;
    rdfs:label "обучается на направлении"@ru ;
    rdfs:domain :Студент ;
    rdfs:range :НаправлениеПодготовки ;
    :mergePolicy :Policy_SetByDate .

:имеетПрофиль rdf:type owl:ObjectProperty ;
    rdfs:label "имеет профиль (направленность)"@ru ;
    rdfs:domain :Студент ;
    rdfs:range :Профиль ;
    :mergePolicy :Policy_SetByDate .

# ---------- Сотрудник ----------

:занимаетДолжность rdf:type owl:ObjectProperty ;
    rdfs:label "занимает должность"@ru ;
    rdfs:domain :Сотрудник ;
    rdfs:range :Должность ;
    :mergePolicy :Policy_Add ;
    rdfs:comment "Сотрудник может занимать несколько должностей одновременно (в т. ч. в разных подразделениях)." .

:работаетВ rdf:type owl:ObjectProperty ;
    rdfs:label "работает в"@ru ;
    rdfs:domain :Сотрудник ;
    rdfs:range :Организация ;
    :mergePolicy :Policy_Add ;
    rdfs:comment "Место работы сотрудника. Возможно несколько одновременно." .

:имеетУченуюСтепень rdf:type owl:ObjectProperty ;
    rdfs:label "имеет учёную степень"@ru ;
    rdfs:domain :Сотрудник ;
    rdfs:range :УченаяСтепень ;
    :mergePolicy :Policy_Add .

:имеетУченоеЗвание rdf:type owl:ObjectProperty ;
    rdfs:label "имеет учёное звание"@ru ;
    rdfs:domain :Сотрудник ;
    rdfs:range :УченоеЗвание ;
    :mergePolicy :Policy_Add .

# ---------- Связь Студент ↔ ВКР, Студент ↔ Практика ----------

:авторВКР rdf:type owl:ObjectProperty ;
    rdfs:label "автор ВКР"@ru ;
    rdfs:domain :ВКР ;
    rdfs:range :Студент ;
    :mergePolicy :Policy_Set ;
    rdfs:comment "У каждой ВКР ровно один автор-студент." .

:имеетВКР rdf:type owl:ObjectProperty ;
    rdfs:label "является автором ВКР"@ru ;
    owl:inverseOf :авторВКР ;
    rdfs:domain :Студент ;
    rdfs:range :ВКР ;
    :mergePolicy :Policy_Add .

:практикантВПрактике rdf:type owl:ObjectProperty ;
    rdfs:label "практикант"@ru ;
    rdfs:domain :Практика ;
    rdfs:range :Студент ;
    :mergePolicy :Policy_Set ;
    rdfs:comment "У одной практики ровно один практикант-студент." .

:имеетПрактику rdf:type owl:ObjectProperty ;
    rdfs:label "проходит практику"@ru ;
    owl:inverseOf :практикантВПрактике ;
    rdfs:domain :Студент ;
    rdfs:range :Практика ;
    :mergePolicy :Policy_Add .

